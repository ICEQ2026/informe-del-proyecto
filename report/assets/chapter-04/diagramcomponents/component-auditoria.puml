@startuml

title Component View - ColdTrace - Maintenance Management BC
caption Current backend package: com.acme.coldtrace.platform.maintenancemanagement

left to right direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false

actor "Web Application / API Client" as client
database "MySQL\nmaintenance_schedules\ntechnical_service_requests" as db

component "IdentityAccessContextFacade" as identity_facade <<External ACL>>
component "AssetManagementContextFacade" as asset_facade <<External ACL>>
component "AlertsContextFacade" as alerts_facade <<External ACL>>

package "Maintenance Management Bounded Context" #FDEBD0 {

  [MaintenanceSchedulesController] <<REST Controller>> as schedules_ctrl
  [TechnicalServiceRequestsController] <<REST Controller>> as requests_ctrl

  [MaintenanceScheduleCommandServiceImpl] <<Command Service>> as schedule_cmd
  [TechnicalServiceRequestCommandServiceImpl] <<Command Service>> as request_cmd
  [MaintenanceScheduleQueryServiceImpl] <<Query Service>> as schedule_query
  [TechnicalServiceRequestQueryServiceImpl] <<Query Service>> as request_query

  [MaintenanceScheduleCreatedEventHandler] <<Event Handler>> as schedule_event_handler
  [TechnicalServiceRequestCreatedEventHandler] <<Event Handler>> as request_event_handler

  [MaintenanceScheduleRepository] <<Domain Repository>> as schedule_repo
  [TechnicalServiceRequestRepository] <<Domain Repository>> as request_repo
  [JPA repository adapters\nPersistence assemblers\nJPA entities] <<Infrastructure>> as persistence
}

client --> schedules_ctrl : /organizations/{id}/maintenance-schedules
client --> requests_ctrl : /organizations/{id}/technical-service-requests

schedules_ctrl --> schedule_cmd : create / update status
schedules_ctrl --> schedule_query : list / get
requests_ctrl --> request_cmd : create / update status
requests_ctrl --> request_query : list / get

schedule_cmd --> identity_facade : validates organization/user
schedule_cmd --> asset_facade : validates maintained asset
schedule_query --> identity_facade : validates organization

request_cmd --> identity_facade : validates organization
request_cmd --> asset_facade : fetches asset snapshot
request_cmd --> alerts_facade : validates related incident
request_query --> identity_facade : validates organization

schedule_cmd --> schedule_repo
schedule_query --> schedule_repo
request_cmd --> request_repo
request_query --> request_repo

schedule_repo --> schedule_event_handler : publishes MaintenanceScheduleCreatedEvent
request_repo --> request_event_handler : publishes TechnicalServiceRequestCreatedEvent
schedule_event_handler --> [MaintenanceScheduleCreatedIntegrationEvent]
request_event_handler --> [TechnicalServiceRequestCreatedIntegrationEvent]

schedule_repo --> persistence
request_repo --> persistence
persistence --> db : Spring Data JPA

@enduml
