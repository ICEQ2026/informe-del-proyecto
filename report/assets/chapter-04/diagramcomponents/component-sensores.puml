@startuml

title Component View - ColdTrace - Asset Management BC
caption Current backend package: com.acme.coldtrace.platform.assetmanagement

left to right direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false

actor "Web Application / API Client" as client
database "MySQL\nlocations\nassets\ngateways\niot_devices\nasset_settings" as db

component "Identity & Access BC\nOrganizationRepository" as identity_bc <<External dependency>>
component "Monitoring / Alerts /\nReports / Maintenance" as other_bcs <<ACL consumers>>

package "Asset Management Bounded Context" #FADBD8 {

  [LocationsController] <<REST Controller>> as locations_ctrl
  [AssetsController] <<REST Controller>> as assets_ctrl
  [GatewaysController] <<REST Controller>> as gateways_ctrl
  [IoTDevicesController] <<REST Controller>> as devices_ctrl
  [AssetSettingsController] <<REST Controller>> as settings_ctrl

  [LocationCommandServiceImpl] <<Command Service>> as location_cmd
  [AssetCommandServiceImpl] <<Command Service>> as asset_cmd
  [GatewayCommandServiceImpl] <<Command Service>> as gateway_cmd
  [IoTDeviceCommandServiceImpl] <<Command Service>> as device_cmd
  [AssetSettingsCommandServiceImpl] <<Command Service>> as settings_cmd

  [LocationQueryServicesImpl] <<Query Service>> as location_query
  [AssetQueryServicesImpl] <<Query Service>> as asset_query
  [GatewayQueryServicesImpl] <<Query Service>> as gateway_query
  [IoTDeviceQueryServicesImpl] <<Query Service>> as device_query
  [AssetSettingsQueryServicesImpl] <<Query Service>> as settings_query

  [AssetManagementContextFacadeImpl] <<ACL Facade>> as asset_facade
  [AssetCreatedEventHandler] <<Event Handler>> as asset_event_handler

  [LocationRepository] <<Domain Repository>> as location_repo
  [AssetRepository] <<Domain Repository>> as asset_repo
  [GatewayRepository] <<Domain Repository>> as gateway_repo
  [IoTDeviceRepository] <<Domain Repository>> as device_repo
  [AssetSettingsRepository] <<Domain Repository>> as settings_repo

  [JPA repository adapters\nPersistence assemblers\nJPA entities] <<Infrastructure>> as persistence
}

client --> locations_ctrl : /organizations/{id}/locations
client --> assets_ctrl : /organizations/{id}/assets
client --> gateways_ctrl : /organizations/{id}/gateways
client --> devices_ctrl : /organizations/{id}/iot-devices
client --> settings_ctrl : /organizations/{id}/asset-settings

locations_ctrl --> location_cmd
locations_ctrl --> location_query
assets_ctrl --> asset_cmd
assets_ctrl --> asset_query
gateways_ctrl --> gateway_cmd
gateways_ctrl --> gateway_query
devices_ctrl --> device_cmd
devices_ctrl --> device_query
settings_ctrl --> settings_cmd
settings_ctrl --> settings_query

location_cmd --> identity_bc : validates organization
asset_cmd --> identity_bc : validates organization
gateway_cmd --> identity_bc : validates organization
device_cmd --> identity_bc : validates organization
settings_cmd --> identity_bc : validates organization

location_cmd --> location_repo
location_query --> location_repo
asset_cmd --> asset_repo
asset_cmd --> location_repo
asset_query --> asset_repo
gateway_cmd --> gateway_repo
gateway_cmd --> location_repo
gateway_query --> gateway_repo
device_cmd --> device_repo
device_cmd --> gateway_repo
device_cmd --> asset_repo
device_query --> device_repo
settings_cmd --> settings_repo
settings_cmd --> asset_repo
settings_query --> settings_repo
settings_query --> asset_repo

asset_repo --> asset_event_handler : publishes AssetCreatedEvent
asset_event_handler --> [AssetCreatedIntegrationEvent]

asset_facade --> asset_repo
asset_facade --> device_repo
asset_facade --> gateway_repo
asset_facade --> settings_repo
other_bcs ..> asset_facade : fetch snapshots/settings

location_repo --> persistence
asset_repo --> persistence
gateway_repo --> persistence
device_repo --> persistence
settings_repo --> persistence
persistence --> db : Spring Data JPA

@enduml
