@startuml

title Component View - ColdTrace - Monitoring BC
caption Current backend package: com.acme.coldtrace.platform.monitoring

left to right direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam shadowing false

actor "Web Application / API Client" as client
database "MySQL\nsensor_readings" as db

component "IdentityAccessContextFacade" as identity_facade <<External ACL>>
component "AssetManagementContextFacade" as asset_facade <<External ACL>>
component "Reports / Alerts" as other_bcs <<ACL consumers>>

package "Monitoring Bounded Context" #D5F5E3 {

  [SensorReadingsController] <<REST Controller>> as readings_ctrl
  [SensorReadingCommandServiceImpl] <<Command Service>> as reading_cmd
  [SensorReadingQueryServiceImpl] <<Query Service>> as reading_query
  [MonitoringContextFacadeImpl] <<ACL Facade>> as monitoring_facade
  [SensorReadingRecordedEventHandler] <<Event Handler>> as reading_event_handler

  [SensorReadingRepository] <<Domain Repository>> as reading_repo
  [JPA repository adapter\nPersistence assembler\nSensorReadingPersistenceEntity] <<Infrastructure>> as persistence
}

client --> readings_ctrl : /organizations/{id}/sensor-readings
readings_ctrl --> reading_cmd : create reading / demo generation
readings_ctrl --> reading_query : list / get reading

reading_cmd --> identity_facade : validates organization
reading_cmd --> asset_facade : validates asset, IoT device,\ngateway and settings
reading_query --> identity_facade : validates organization

reading_cmd --> reading_repo
reading_query --> reading_repo
monitoring_facade --> reading_repo
other_bcs ..> monitoring_facade : fetch reading snapshots

reading_repo --> reading_event_handler : publishes SensorReadingRecordedEvent
reading_event_handler --> [SensorReadingRecordedIntegrationEvent]

reading_repo --> persistence
persistence --> db : Spring Data JPA

@enduml
