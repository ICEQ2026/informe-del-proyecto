@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title System Context Diagram - ColdTrace (ICEQ)
caption General system context for food cold-chain monitoring

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

' Main actors
Person(owner, "Business Owner or Store Manager", "Segment 1 (Gustavo). Manages minimarkets, butcher shops, fish shops, or restaurants. Monitors temperature and handles alerts from a mobile device.")

Person(operations_lead, "Operations or Quality Lead", "Segment 2 (Sofia). Supervises multiple refrigerated assets, configures safety ranges, generates reports, and supports compliance evidence.")

Person(admin, "Organization Administrator", "Manages users, roles, and permissions within the business account [US011].")

Person_Ext(auditor, "Health Auditor (DIGESA / MINSA)", "External actor who receives exported reports and traceability evidence to support regulatory compliance [EP006, Reports & Compliance].")

' Main system
System(coldtrace, "ColdTrace", "SaaS web monitoring platform for food cold-chain operations. Centralizes assets, readings, alerts, reports, AI-assisted incident guidance, and subscriptions.")

' External systems
System_Ext(sensors, "IoT Sensors", "Physical devices installed in cold rooms, warehouses, and transport units. Capture temperature and humidity [EP003, EP004, BC Monitoring].")

System_Ext(email, "Email Service", "External provider such as SendGrid or Mailgun. Handles password recovery, account communication, and alerts [EP002, EP005].")

System_Ext(push, "Push Notification Service", "Delivers critical real-time alerts to the user's browser and mobile device [EP005].")

System_Ext(whatsapp, "Messaging Service (WhatsApp Business API)", "Complementary critical-alert channel based on the stakeholders' usual communication habits [EP005].")

System_Ext(ai_provider, "AI Model Provider", "Spring AI target selected by environment: Ollama gemma3:4b locally, OpenAI gpt-5.4-mini in academic deployment [EP013].")

System_Ext(stripe, "Stripe", "External payment provider. Handles hosted checkout, customer portal, invoices, and subscription lifecycle events [EP014].")

' Main relationships
Rel(owner, coldtrace, "Checks asset status and handles alerts", "HTTPS / Responsive Web")
Rel(operations_lead, coldtrace, "Monitors operations, configures ranges, resolves incidents with AI guidance, and generates reports", "HTTPS / Web")
Rel(admin, coldtrace, "Manages users, roles, permissions, plans, and billing", "HTTPS / Web")

Rel(coldtrace, auditor, "Delivers compliance reports and traceability evidence", "PDF / CSV exports")

Rel(sensors, coldtrace, "Sends temperature and humidity readings", "MQTT / HTTP")

Rel(coldtrace, email, "Sends recovery, account, and alert emails", "SMTP / REST API")
Rel(coldtrace, push, "Delivers real-time deviation notifications", "Web Push / FCM")
Rel(coldtrace, whatsapp, "Sends critical alerts through messaging", "REST API")

Rel(coldtrace, ai_provider, "Requests structured AI guidance with bounded operational context", "Spring AI / HTTPS")
Rel(coldtrace, stripe, "Creates hosted checkout and billing portal sessions; receives subscription webhooks", "REST API / HTTPS")

@enduml
