@startuml

title Stage 2: Classes Grouped by Bounded Context - ColdTrace Current Backend

scale 1800 width
skinparam classAttributeIconSize 0
skinparam nodesep 35
skinparam ranksep 40
skinparam packageStyle rectangle
skinparam shadowing false
hide methods

package "BC Identity & Access" #D6EAF8 {

  class Organization <<Aggregate>> {
    - id: Long
    - legalName: String
    - commercialName: String
    - taxId: String
    - contactEmail: EmailAddress
  }

  class User <<Aggregate>> {
    - id: Long
    - uuid: String
    - organizationUserId: Long
    - firstName: String
    - lastName: String
    - email: EmailAddress
    - organizationId: Long
    - roleId: Long
  }

  class Role <<Aggregate>> {
    - id: Long
    - name: RoleName
    - label: String
    - permissions: List<Permission>
  }

  class EmailAddress <<ValueObject>>
  class RoleName <<ValueObject>>
  class Permission <<ValueObject>>

  Organization "1" o-- "*" User : organizationId
  User "*" --> "1" Role : roleId
  Role "1" *-- "*" Permission
  Organization *-- EmailAddress
  User *-- EmailAddress
  Role *-- RoleName
}

package "BC Asset Management" #FADBD8 {
  class Location <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - name: LocationName
    - type: String
    - status: String
  }

  class Asset <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - locationId: Long
    - uuid: AssetUuid
    - type: String
    - name: String
    - capacity: Double
    - status: String
  }

  class Gateway <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - locationId: Long
    - uuid: GatewayUuid
    - name: String
    - network: String
    - status: String
  }

  class IoTDevice <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - gatewayId: Long
    - uuid: IoTDeviceUuid
    - deviceType: String
    - measurementType: String
    - assetId: Long
    - status: String
  }

  class AssetSettings <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - assetId: Long
    - minimumTemperature: Double
    - maximumTemperature: Double
    - minimumHumidity: Double
    - maximumHumidity: Double
  }

  class LocationName <<ValueObject>>
  class AssetUuid <<ValueObject>>
  class GatewayUuid <<ValueObject>>
  class IoTDeviceUuid <<ValueObject>>
  class AssetCreatedEvent <<DomainEvent>>

  Location "1" <-- "*" Asset : locationId
  Location "1" <-- "*" Gateway : locationId
  Gateway "1" <-- "*" IoTDevice : gatewayId
  Asset "0..1" <-- "*" IoTDevice : assetId
  Asset "0..1" <-- "*" AssetSettings : assetId
  Location *-- LocationName
  Asset *-- AssetUuid
  Gateway *-- GatewayUuid
  IoTDevice *-- IoTDeviceUuid
  Asset ..> AssetCreatedEvent : publishes
}

package "BC Monitoring" #D5F5E3 {
  class SensorReading <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - assetId: Long
    - iotDeviceId: Long
    - gatewayId: Long
    - locationId: Long
    - temperature: Double
    - humidity: Double
    - outOfRange: Boolean
    - recordedAt: OffsetDateTime
  }
}

package "BC Alerts" #FCF3CF {
  class Incident <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - assetId: Long
    - deviceId: Long
    - readingId: Long
    - severity: IncidentSeverity
    - status: IncidentStatus
  }

  class Notification <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - incidentId: Long
    - channel: NotificationChannel
    - status: NotificationStatus
  }

  enum IncidentSeverity
  enum IncidentStatus
  enum NotificationChannel
  enum NotificationStatus

  Incident "1" <-- "*" Notification : incidentId
  Incident ..> IncidentSeverity
  Incident ..> IncidentStatus
  Notification ..> NotificationChannel
  Notification ..> NotificationStatus
}

package "BC Maintenance Management" #FDEBD0 {
  class MaintenanceSchedule <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - assetId: Long
    - scheduledDate: OffsetDateTime
    - responsibleUserId: Long
    - status: String
  }

  class TechnicalServiceRequest <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - assetId: Long
    - incidentId: Long
    - priority: String
    - status: String
    - evidence: String
  }
}

package "BC Reports" #E8DAEF {
  class Report <<Aggregate>> {
    - id: Long
    - organizationId: Long
    - uuid: String
    - type: String
    - title: String
    - assetCount: Integer
    - readingCount: Integer
    - incidentCount: Integer
    - compliancePercentage: Double
  }
}

Organization "1" ..> "*" Location : organizationId
Organization "1" ..> "*" Asset : organizationId
Organization "1" ..> "*" Gateway : organizationId
Organization "1" ..> "*" IoTDevice : organizationId
Organization "1" ..> "*" SensorReading : organizationId
Organization "1" ..> "*" Incident : organizationId
Organization "1" ..> "*" MaintenanceSchedule : organizationId
Organization "1" ..> "*" TechnicalServiceRequest : organizationId
Organization "1" ..> "*" Report : organizationId

Asset "1" ..> "*" SensorReading : assetId
IoTDevice "1" ..> "*" SensorReading : iotDeviceId
SensorReading "0..1" ..> "*" Incident : readingId
Incident "0..1" ..> "*" TechnicalServiceRequest : incidentId
Asset "1" ..> "*" MaintenanceSchedule : assetId
Asset "1" ..> "*" TechnicalServiceRequest : assetId
Report ..> SensorReading : metrics
Report ..> Incident : metrics
Report ..> Asset : metrics

@enduml
