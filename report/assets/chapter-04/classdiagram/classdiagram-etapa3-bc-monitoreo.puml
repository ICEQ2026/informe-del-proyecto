@startuml

title Stage 3 - BC Monitoring

skinparam classAttributeIconSize 0
skinparam nodesep 45
skinparam ranksep 55
skinparam packageStyle rectangle
skinparam shadowing false

package "BC Monitoring" #D5F5E3 {

  class SensorReading <<Aggregate>> #FADBD8 {
    - id: Long
    - organizationId: Long
    - assetId: Long
    - iotDeviceId: Long
    - gatewayId: Long
    - locationId: Long
    - temperature: Double
    - humidity: Double
    - outOfRange: Boolean
    - recordedAt: OffsetDateTime
    - motionDetected: Boolean
    - imageCaptured: Boolean
    - batteryLevel: Integer
    - signalStrength: Integer
    + onRecorded(): void
  }

  class SensorReadingRecordedEvent <<DomainEvent>> {
    + sensorReadingId: Long
    + organizationId: Long
    + assetId: Long
    + iotDeviceId: Long
    + outOfRange: Boolean
    + recordedAt: OffsetDateTime
  }

  interface SensorReadingRepository <<Repository>>

  SensorReadingRepository ..> SensorReading
  SensorReading ..> SensorReadingRecordedEvent : publishes
}

note right of SensorReading
  The implemented backend stores telemetry
  as one SensorReading aggregate. There is
  no abstract Measurement hierarchy.
end note

@enduml
