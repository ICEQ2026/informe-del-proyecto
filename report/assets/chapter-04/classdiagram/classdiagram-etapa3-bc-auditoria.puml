@startuml

title Stage 3 - BC Maintenance Management

skinparam classAttributeIconSize 0
skinparam nodesep 45
skinparam ranksep 55
skinparam packageStyle rectangle
skinparam shadowing false

package "BC Maintenance Management" #FDEBD0 {

  class MaintenanceSchedule <<Aggregate>> #FADBD8 {
    - id: Long
    - organizationId: Long
    - uuid: String
    - assetId: Long
    - scheduledDate: OffsetDateTime
    - frequencyDays: Integer
    - responsibleUserId: Long
    - observations: String
    - status: String
    - registeredAt: OffsetDateTime
    + isActive(): boolean
    + canTransitionTo(status: String): boolean
    + updateStatus(status: String): void
    + onCreated(): void
  }

  class TechnicalServiceRequest <<Aggregate>> #FADBD8 {
    - id: Long
    - organizationId: Long
    - code: String
    - assetId: Long
    - assetLocationId: Long
    - assetName: String
    - incidentId: Long
    - issueDescription: String
    - priority: String
    - status: String
    - requestedBy: String
    - requestedAt: OffsetDateTime
    - closedAt: OffsetDateTime
    - closureSummary: String
    - evidence: String
    - closedBy: String
    + canTransitionTo(status: String): boolean
    + isActive(): boolean
    + updateStatus(command): void
    + onCreated(): void
  }

  class MaintenanceScheduleCreatedEvent <<DomainEvent>> {
    + maintenanceScheduleId: Long
    + organizationId: Long
    + assetId: Long
    + uuid: String
    + scheduledDate: OffsetDateTime
  }

  class TechnicalServiceRequestCreatedEvent <<DomainEvent>> {
    + technicalServiceRequestId: Long
    + organizationId: Long
    + assetId: Long
    + code: String
    + requestedAt: OffsetDateTime
  }

  interface MaintenanceScheduleRepository <<Repository>>
  interface TechnicalServiceRequestRepository <<Repository>>

  MaintenanceSchedule ..> MaintenanceScheduleCreatedEvent : publishes
  TechnicalServiceRequest ..> TechnicalServiceRequestCreatedEvent : publishes
  TechnicalServiceRequest ..> MaintenanceSchedule : same asset lifecycle
  MaintenanceScheduleRepository ..> MaintenanceSchedule
  TechnicalServiceRequestRepository ..> TechnicalServiceRequest
}

note right of TechnicalServiceRequest
  Evidence is currently a String field in
  TechnicalServiceRequest. There is no
  ServiceEvidence entity class.
end note

@enduml
