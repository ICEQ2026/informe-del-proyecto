@startuml ColdTrace-Stage3-BC-Autenticacion

title Etapa 3 - BC Autenticacion

skinparam classAttributeIconSize 0
skinparam nodesep 45
skinparam ranksep 55
skinparam packageStyle rectangle

package "BC Autenticacion" #D6EAF8 {

  class Usuario <<Aggregate>> #FADBD8 {
    - id: UUID
    - idOrganizacion: UUID
    - email: String
    - nombreUsuario: String
    - passwordHash: String
    - estado: EstadoUsuario
    - fechaCreacion: LocalDateTime
    - fechaVerificacion: LocalDateTime
    + registrar(): void
    + verificarCuenta(token: String): boolean
    + iniciarSesion(pwd: String): Sesion
    + cerrarSesion(): void
    + solicitarRecuperacion(): void
    + asignarRol(rol: Rol): void
  }

  class Organizacion <<Aggregate>> #FADBD8 {
    - idOrganizacion: UUID
    - razonSocial: String
    - ruc: String
    - direccion: String
    + agregarUsuario(u: Usuario): void
    + eliminarUsuario(id: UUID): void
  }

  class Sesion <<Entity>> {
    - idSesion: UUID
    - token: String
    - creadaEn: LocalDateTime
    - expiraEn: LocalDateTime
    + estaVigente(): boolean
    + invalidar(): void
  }

  class Rol <<Entity>> {
    - idRol: UUID
    - nombre: String
    - descripcion: String
  }

  class Suscripcion <<Entity>> {
    - idSuscripcion: UUID
    - plan: String
    - estado: EstadoSuscripcion
    - fechaInicio: LocalDate
    - fechaFin: LocalDate
    + estaVigente(): boolean
    + renovar(): void
    + cancelar(): void
  }

  class Permiso <<ValueObject>> #FCF3CF {
    - nombre: String
    - recurso: String
    - accion: String
  }

  class PreferenciaNotificacion <<ValueObject>> #FCF3CF {
    - canalesHabilitados: Set<String>
    - horarioInicio: LocalTime
    - horarioFin: LocalTime
    - severidadMinima: Severidad
    + aceptaCanal(canal: String): boolean
  }

  enum EstadoUsuario <<enum>> {
    PENDIENTE_VERIFICACION
    ACTIVO
    SUSPENDIDO
    ELIMINADO
  }

  enum EstadoSuscripcion <<enum>> {
    ACTIVA
    VENCIDA
    CANCELADA
    EN_PRUEBA
  }

  class UsuarioRepository {
    + buscarPorNombreUsuario(nombre: String): Optional<Usuario>
    + buscarPorEmail(email: String): Optional<Usuario>
    + obtenerCredencial(id: UUID): Optional<String>
    + guardarSesion(s: Sesion): void
    + invalidarSesion(id: UUID): void
    + guardar(u: Usuario): void
  }

  Usuario "1" o-- "*" Sesion
  Usuario "*" -- "*" Rol
  Rol "*" o-- "*" Permiso
  Organizacion "1" *-- "1" Suscripcion
  Organizacion "1" o-- "*" Usuario
  Usuario "1" *-- "1" PreferenciaNotificacion
  Usuario ..> EstadoUsuario
  Suscripcion ..> EstadoSuscripcion
  UsuarioRepository ..> Usuario
}

@enduml
