@startuml

title ColdTrace - Entity-Relationship Diagram - Current Backend
caption MySQL schema inferred from JPA persistence entities and Hibernate snake_case naming

hide circle
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam nodesep 40
skinparam ranksep 55
skinparam shadowing false

' Shared persistence base
' Every JPA entity extends AuditableAbstractPersistenceEntity:
' id BIGINT PK, created_at DATETIME(6), updated_at DATETIME(6)

' Identity & Access
entity "organizations" as organizations #D6EAF8 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  legal_name : VARCHAR NOT NULL
  commercial_name : VARCHAR NOT NULL
  tax_id : VARCHAR
  contact_email : VARCHAR NOT NULL
}

entity "roles" as roles #D6EAF8 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  name : VARCHAR NOT NULL <<UK>>
  label : VARCHAR NOT NULL
}

entity "role_permissions" as role_permissions #D6EAF8 {
  * role_id : BIGINT <<FK>>
  * id : BIGINT
  --
  resource : VARCHAR
  action : VARCHAR
  description : VARCHAR
}

entity "users" as users #D6EAF8 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  uuid : VARCHAR
  organization_user_id : BIGINT
  first_name : VARCHAR NOT NULL
  last_name : VARCHAR NOT NULL
  email : VARCHAR NOT NULL <<UK>>
  organization_id : BIGINT <<logical FK>>
  role_id : BIGINT <<logical FK>>
}

' Asset Management
entity "locations" as locations #FADBD8 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  name : VARCHAR NOT NULL
  type : VARCHAR NOT NULL
  address : VARCHAR
  description : VARCHAR
  status : VARCHAR NOT NULL
  --
  UK (organization_id, name)
}

entity "assets" as assets #FADBD8 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  location_id : BIGINT <<logical FK>>
  uuid : VARCHAR NOT NULL
  type : VARCHAR NOT NULL
  name : VARCHAR NOT NULL
  capacity : DOUBLE NOT NULL
  description : VARCHAR
  status : VARCHAR NOT NULL
  --
  UK (organization_id, uuid)
}

entity "gateways" as gateways #FADBD8 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  location_id : BIGINT <<logical FK>>
  uuid : VARCHAR NOT NULL
  name : VARCHAR NOT NULL
  network : VARCHAR NOT NULL
  status : VARCHAR NOT NULL
  --
  UK (organization_id, uuid)
}

entity "iot_devices" as iot_devices #FADBD8 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  gateway_id : BIGINT <<logical FK>>
  uuid : VARCHAR NOT NULL
  device_type : VARCHAR NOT NULL
  model : VARCHAR NOT NULL
  measurement_type : VARCHAR NOT NULL
  reading_frequency_seconds : INT NOT NULL
  asset_id : BIGINT <<logical FK, NULL>>
  status : VARCHAR NOT NULL
  calibration_status : VARCHAR NOT NULL
  last_calibration_date : DATE NOT NULL
  next_calibration_date : DATE NOT NULL
  --
  UK (organization_id, uuid)
}

entity "iot_device_measurement_parameters" as iot_device_measurement_parameters #FADBD8 {
  * iot_device_id : BIGINT <<FK>>
  * measurement_parameter : VARCHAR
}

entity "asset_settings" as asset_settings #FADBD8 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  asset_id : BIGINT <<logical FK, NULL>>
  uuid : VARCHAR NOT NULL
  minimum_temperature : DOUBLE NOT NULL
  maximum_temperature : DOUBLE NOT NULL
  minimum_humidity : DOUBLE NOT NULL
  maximum_humidity : DOUBLE NOT NULL
  calibration_frequency_days : INT NOT NULL
  temperature_unit : VARCHAR NOT NULL
  humidity_unit : VARCHAR NOT NULL
  weight_unit : VARCHAR NOT NULL
  reading_frequency_seconds : INT NOT NULL
  alert_threshold_minutes : INT NOT NULL
}

entity "asset_settings_asset_types" as asset_settings_asset_types #FADBD8 {
  * asset_settings_id : BIGINT <<FK>>
  * asset_type : VARCHAR
}

entity "asset_settings_iot_device_types" as asset_settings_iot_device_types #FADBD8 {
  * asset_settings_id : BIGINT <<FK>>
  * iot_device_type : VARCHAR
}

' Monitoring
entity "sensor_readings" as sensor_readings #D5F5E3 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  asset_id : BIGINT <<logical FK>>
  iot_device_id : BIGINT <<logical FK>>
  gateway_id : BIGINT <<logical FK>>
  location_id : BIGINT <<logical FK>>
  temperature : DOUBLE
  humidity : DOUBLE
  out_of_range : BOOLEAN NOT NULL
  recorded_at : DATETIME NOT NULL
  motion_detected : BOOLEAN
  image_captured : BOOLEAN
  battery_level : INT
  signal_strength : INT
}

' Alerts
entity "incidents" as incidents #FCF3CF {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  asset_id : BIGINT <<logical FK, NULL>>
  device_id : BIGINT <<logical FK, NULL>>
  reading_id : BIGINT <<logical FK, NULL>>
  asset_name : VARCHAR
  device_name : VARCHAR
  type : VARCHAR NOT NULL
  severity : VARCHAR NOT NULL
  status : VARCHAR NOT NULL
  value : VARCHAR
  detected_at : DATETIME NOT NULL
  acknowledged_at : DATETIME
  acknowledged_by : VARCHAR
  escalated_at : DATETIME
  escalated_by : VARCHAR
  escalation_reason : VARCHAR
  corrective_action_registered_at : DATETIME
  corrective_action_registered_by : VARCHAR
  corrective_action : VARCHAR
  resolved_at : DATETIME
  resolved_by : VARCHAR
  resolution_notes : VARCHAR
  last_notification_status : VARCHAR
  last_notification_at : DATETIME
  notification_count : INT
}

entity "notifications" as notifications #FCF3CF {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  incident_id : BIGINT <<logical FK>>
  channel : VARCHAR NOT NULL
  recipient : VARCHAR
  message : VARCHAR NOT NULL
  status : VARCHAR NOT NULL
  delivered_at : DATETIME
  failure_reason : VARCHAR
}

' Maintenance Management
entity "maintenance_schedules" as maintenance_schedules #FDEBD0 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  uuid : VARCHAR NOT NULL
  asset_id : BIGINT <<logical FK>>
  scheduled_date : DATETIME NOT NULL
  frequency_days : INT
  responsible_user_id : BIGINT <<logical FK, NULL>>
  observations : VARCHAR(1000)
  status : VARCHAR NOT NULL
  registered_at : DATETIME NOT NULL
}

entity "technical_service_requests" as technical_service_requests #FDEBD0 {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  code : VARCHAR NOT NULL
  asset_id : BIGINT <<logical FK>>
  asset_location_id : BIGINT <<logical FK>>
  asset_name : VARCHAR NOT NULL
  incident_id : BIGINT <<logical FK, NULL>>
  issue_description : VARCHAR(1000) NOT NULL
  priority : VARCHAR NOT NULL
  status : VARCHAR NOT NULL
  requested_by : VARCHAR
  requested_at : DATETIME NOT NULL
  closed_at : DATETIME
  closure_summary : VARCHAR(1000)
  evidence : VARCHAR(1000)
  closed_by : VARCHAR
}

' Reports
entity "reports" as reports #E8DAEF {
  * id : BIGINT <<PK>>
  --
  created_at : DATETIME(6) NOT NULL
  updated_at : DATETIME(6) NOT NULL
  organization_id : BIGINT <<logical FK>>
  uuid : VARCHAR NOT NULL
  type : VARCHAR NOT NULL
  title : VARCHAR NOT NULL
  period_start : DATETIME NOT NULL
  period_end : DATETIME NOT NULL
  generated_at : DATETIME NOT NULL
  asset_count : INT NOT NULL
  reading_count : INT NOT NULL
  out_of_range_reading_count : INT NOT NULL
  incident_count : INT NOT NULL
  open_incident_count : INT NOT NULL
  average_temperature : DOUBLE
  average_humidity : DOUBLE
  compliance_percentage : DOUBLE
}

organizations ||..o{ users : organization_id
roles ||..o{ users : role_id
roles ||--o{ role_permissions : role_id

organizations ||..o{ locations : organization_id
organizations ||..o{ assets : organization_id
locations ||..o{ assets : location_id
organizations ||..o{ gateways : organization_id
locations ||..o{ gateways : location_id
organizations ||..o{ iot_devices : organization_id
gateways ||..o{ iot_devices : gateway_id
assets ||..o{ iot_devices : asset_id
iot_devices ||--o{ iot_device_measurement_parameters : iot_device_id
organizations ||..o{ asset_settings : organization_id
assets ||..o{ asset_settings : asset_id
asset_settings ||--o{ asset_settings_asset_types : asset_settings_id
asset_settings ||--o{ asset_settings_iot_device_types : asset_settings_id

organizations ||..o{ sensor_readings : organization_id
assets ||..o{ sensor_readings : asset_id
iot_devices ||..o{ sensor_readings : iot_device_id
gateways ||..o{ sensor_readings : gateway_id
locations ||..o{ sensor_readings : location_id

organizations ||..o{ incidents : organization_id
assets ||..o{ incidents : asset_id
iot_devices ||..o{ incidents : device_id
sensor_readings ||..o{ incidents : reading_id
organizations ||..o{ notifications : organization_id
incidents ||..o{ notifications : incident_id

organizations ||..o{ maintenance_schedules : organization_id
assets ||..o{ maintenance_schedules : asset_id
users ||..o{ maintenance_schedules : responsible_user_id
organizations ||..o{ technical_service_requests : organization_id
assets ||..o{ technical_service_requests : asset_id
locations ||..o{ technical_service_requests : asset_location_id
incidents ||..o{ technical_service_requests : incident_id

organizations ||..o{ reports : organization_id

@enduml
